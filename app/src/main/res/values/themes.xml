<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main Application Theme -->
    <style name="Theme.AndroidDevSuite" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Tertiary colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        <!-- Window -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowContentTransitions">true</item>
        
        <!-- Ripple -->
        <item name="colorControlHighlight">#1AFFFFFF</item>
    </style>
    
    <!-- Terminal Theme -->
    <style name="Theme.AndroidDevSuite.Terminal" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:colorBackground">@color/terminal_background</item>
        <item name="android:statusBarColor">@color/terminal_background</item>
        <item name="android:navigationBarColor">@color/terminal_background</item>
    </style>
    
    <!-- Block Editor Theme -->
    <style name="Theme.AndroidDevSuite.Blocks" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/block_control</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
    
    <!-- Settings Theme -->
    <style name="Theme.AndroidDevSuite.Settings" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
    
    <!-- Compose Theme Reference -->
    <style name="Theme.AndroidDevSuite.Compose" parent="android:Theme.Material.NoActionBar" />
</resources>
